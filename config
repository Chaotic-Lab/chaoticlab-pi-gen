# Vena Pulse image config (consumed by pi-gen + pi-gen-action)
IMG_NAME="vena-pulse"
RELEASE="bookworm"
DEPLOY_COMPRESSION="xz"
COMPRESSION_LEVEL="9"
LOCALE_DEFAULT="pt_BR.UTF-8"
TIMEZONE_DEFAULT="America/Sao_Paulo"
KEYBOARD_KEYMAP="br"
KEYBOARD_LAYOUT="Portuguese (Brazil)"
FIRST_USER_NAME="vena"
HOSTNAME="vena-pulse"
ENABLE_SSH=1
PUBKEY_ONLY_SSH=1
DISABLE_FIRST_BOOT_USER_RENAME=1
STAGE_LIST="stage0 stage1 stage2 ./stage-tdc"
